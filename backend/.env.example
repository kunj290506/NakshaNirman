# AutoArchitect AI Environment Variables
# Copy this file to .env and fill in your values

# Gemini API Key (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Use Gemini AI for intelligent room layout (set to false to use algorithm only)
USE_GEMINI=true

# Debug mode
DEBUG=false
