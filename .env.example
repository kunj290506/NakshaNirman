# ─── CAD Floor Plan Generator ───

# OpenRouter API — text model (optional) + image model (FLUX)
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_SECONDARY=
OPENROUTER_MODEL=black-forest-labs/flux.2-klein-4b
OPENROUTER_TEXT_MODEL=deepseek/deepseek-r1
OPENROUTER_PLANNER_MODEL=deepseek/deepseek-chat
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
OPENROUTER_TEXT_TEMPERATURE=0.3
OPENROUTER_TEXT_MAX_TOKENS=2400
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ENABLED=false
OPENROUTER_VERIFY_SSL=true

# Free student mode (recommended): no paid API calls
FORCE_LOCAL_PLANNER=true
FAST_FALLBACK_MODE=true
ARCHITECT_REASONING_ENABLED=true
PUBLIC_LLM_FALLBACK_ENABLED=true
PUBLIC_LLM_FALLBACK_URL=https://text.pollinations.ai/openai
PUBLIC_LLM_FALLBACK_MODEL=openai

# Local API burst handling
RATE_LIMIT_GENERATE_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BYPASS_LOCAL=true

# Optional paid provider (leave empty in free mode)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Security
SECRET_KEY=change-me-in-production
