# ─── CAD Floor Plan Generator ───

# Groq API — Primary AI engine (get FREE key at console.groq.com)
# Free tier: 14,400 requests/day, 30 requests/minute
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Grok (xAI) API — Optional advisor (get key at console.x.ai)
GROK_API_KEY=
GROK_MODEL=grok-3-mini
GROK_BASE_URL=https://api.x.ai/v1

# OpenRouter API — text model (optional) + image model (FLUX)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=black-forest-labs/flux.2-klein-4b
OPENROUTER_TEXT_MODEL=
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ENABLED=true
OPENROUTER_VERIFY_SSL=true

# Security
SECRET_KEY=change-me-in-production
