# ─── CAD Floor Plan Generator ───

# OpenRouter API — text model (optional) + image model (FLUX)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=black-forest-labs/flux.2-klein-4b
OPENROUTER_TEXT_MODEL=deepseek/deepseek-r1
OPENROUTER_PLANNER_MODEL=deepseek/deepseek-chat
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
OPENROUTER_TEXT_TEMPERATURE=0.3
OPENROUTER_TEXT_MAX_TOKENS=2400
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ENABLED=true
OPENROUTER_VERIFY_SSL=true

# Security
SECRET_KEY=change-me-in-production
